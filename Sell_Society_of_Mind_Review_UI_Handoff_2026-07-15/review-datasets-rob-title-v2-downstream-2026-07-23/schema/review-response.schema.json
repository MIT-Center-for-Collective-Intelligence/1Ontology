{
  "$ref": "#/definitions/SocietyOfMindReviewResponse",
  "definitions": {
    "SocietyOfMindReviewResponse": {
      "type": "object",
      "properties": {
        "schemaVersion": {
          "type": "string",
          "const": "som-review-v1"
        },
        "datasetVersion": {
          "type": "string",
          "minLength": 1
        },
        "proposalId": {
          "$ref": "#/definitions/SocietyOfMindReviewResponse/properties/datasetVersion"
        },
        "reviewerId": {
          "$ref": "#/definitions/SocietyOfMindReviewResponse/properties/datasetVersion"
        },
        "decision": {
          "type": "string",
          "enum": [
            "agree",
            "disagree"
          ]
        },
        "disagreementReason": {
          "type": "string",
          "maxLength": 2000,
          "default": ""
        },
        "suggestedCorrection": {
          "type": "string",
          "maxLength": 2000,
          "default": ""
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "elapsedMs": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "schemaVersion",
        "datasetVersion",
        "proposalId",
        "reviewerId",
        "decision",
        "reviewedAt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
